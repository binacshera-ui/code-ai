NODE_ENV=production
PORT=4000
PM2_APP_NAME=code-ai-app

# Open access is enabled by default for this control surface.
CODEX_OPEN_ACCESS=true
CODEX_ALLOW_ANY_PATHS=true

# Optional: restrict open access to explicit hosts by setting both:
# CODEX_OPEN_ACCESS=false
# CODEX_PUBLIC_HOSTS=app-codex.example.com
CODEX_PUBLIC_HOSTS=

# Optional: enable persistent session store if you need shared auth.
DATABASE_URL=
SESSION_SECRET=change-me
SESSION_COOKIE_DOMAIN=
CODEX_DEVICE_ADMIN_PASSWORD=403005Ashim@

# Optional: custom binary path for the Codex CLI.
CODEX_BIN=codex

# Storage roots
CODEX_APP_ROOT=
CODEX_STORAGE_ROOT=
CODEX_UPLOAD_ROOT=
CODEX_QUEUE_ROOT=
CODEX_LOG_ROOT=

# Optional extra readable roots for file preview/download.
CODEX_ALLOWED_FILE_ROOTS=

# Main runtime configuration: one or more Codex homes/workspaces.
# Replace the example paths below before first deploy.
CODEX_PROFILES_JSON=[{"id":"default","label":"Default","codexHome":"/home/ubuntu/.codex","workspaceCwd":"/srv/codex-workspace","defaultProfile":true}]
