# code-ai standalone example environment
#
# In normal installs you do not need to write this file by hand.
# `./install.sh` or `install.ps1` will generate `.env` for you.
#
# This file exists so operators and AI agents can understand the final shape.

NODE_ENV=production
PORT=4000
PM2_APP_NAME=code-ai

# Optional. Usually auto-detected from repo root.
# CODEX_APP_ROOT=/srv/code-ai

# Main Codex runtime
# If `codex` is in PATH, leave CODEX_BIN=codex.
# Otherwise set the full path, for example:
# CODEX_BIN=/usr/local/bin/codex
# CODEX_BIN=C:\Tools\codex\codex.exe
CODEX_BIN=codex

# Required in practice. Change this.
CODEX_DEVICE_ADMIN_PASSWORD=change-me

# UI access model
CODEX_OPEN_ACCESS=true
CODEX_PUBLIC_HOSTS=
CODEX_ALLOW_ANY_PATHS=true
CODEX_ALLOWED_FILE_ROOTS=

# Browser auth / session storage
# SESSION_SECRET should be changed in real installs.
SESSION_SECRET=change-me-too
SESSION_COOKIE_DOMAIN=

# Optional Postgres URL.
# If empty, browser sessions fall back to in-memory storage.
DATABASE_URL=

# Storage roots used by the app itself
CODEX_STORAGE_ROOT=/srv/code-ai-data
CODEX_UPLOAD_ROOT=/srv/code-ai-data/uploads
CODEX_QUEUE_ROOT=/srv/code-ai-data/queue
CODEX_LOG_ROOT=/srv/code-ai-data/logs

# Profiles JSON must be a JSON array string.
# This is the most important setting after CODEX_BIN.
#
# `codexHome` must point at the real Codex data home that contains:
# - session_index.jsonl
# - sessions/
# - sometimes archived_sessions/
#
# `workspaceCwd` is the default folder shown in the mobile UI for new chats.
#
# Linux example:
# CODEX_PROFILES_JSON=[{"id":"default","label":"Default","codexHome":"/home/ubuntu/.codex","workspaceCwd":"/srv/codex-workspace","defaultProfile":true}]
#
# Windows example:
# CODEX_PROFILES_JSON=[{"id":"default","label":"Default","codexHome":"C:\\Users\\Administrator\\.codex","workspaceCwd":"D:\\codex-workspace","defaultProfile":true}]
CODEX_PROFILES_JSON=[{"id":"default","label":"Default","codexHome":"/home/ubuntu/.codex","workspaceCwd":"/srv/codex-workspace","defaultProfile":true}]
