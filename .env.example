# code-ai standalone example environment
#
# In normal installs you do not need to write this file by hand.
# `./install.sh` or `install.ps1` will generate `.env` for you.
#
# This file exists so operators and AI agents can understand the final shape.
# code-ai is a shared workspace for Codex, Claude, and Gemini.

NODE_ENV=production
PORT=4000
PM2_APP_NAME=code-ai

# Optional. Usually auto-detected from repo root.
# CODEX_APP_ROOT=/srv/code-ai

# Provider binaries
# If the binaries are in PATH, you can usually leave these as-is.
# Otherwise set explicit full paths.
#
# Examples:
# CODEX_BIN=/usr/local/bin/codex
# CODEX_BIN=C:\Tools\codex\codex.exe
CODEX_BIN=codex
CLAUDE_BIN=claude
GEMINI_BIN=gemini

# Required in practice. Change this.
CODEX_DEVICE_ADMIN_PASSWORD=change-me

# UI access model
CODEX_OPEN_ACCESS=true
CODEX_PUBLIC_HOSTS=
CODEX_ALLOW_ANY_PATHS=true
CODEX_ALLOWED_FILE_ROOTS=

# Browser auth / session storage
# SESSION_SECRET should be changed in real installs.
SESSION_SECRET=change-me-too
SESSION_COOKIE_DOMAIN=

# Optional Postgres URL.
# If empty, browser sessions fall back to in-memory storage.
DATABASE_URL=

# Storage roots used by the app itself
CODEX_STORAGE_ROOT=/srv/code-ai-data
CODEX_UPLOAD_ROOT=/srv/code-ai-data/uploads
CODEX_QUEUE_ROOT=/srv/code-ai-data/queue
CODEX_LOG_ROOT=/srv/code-ai-data/logs

# Profiles JSON must be a JSON array string.
# This is the most important setting in the whole app.
#
# Legacy naming note:
# `codexHome` now means "provider data home" for any provider.
#
# Examples:
# - provider=codex  -> /home/ubuntu/.codex
# - provider=claude -> /home/ubuntu/.claude
# - provider=gemini -> /home/ubuntu/.gemini
#
# Codex homes typically contain:
# - session_index.jsonl
# - sessions/
# - sometimes archived_sessions/
#
# Claude homes typically contain:
# - projects/<workspace>/*.jsonl
#
# Gemini homes typically contain:
# - projects.json
# - tmp/<project-id>/chats/*.jsonl
#
# `workspaceCwd` is the default folder shown in the mobile UI for new chats.
#
# Linux multi-provider example:
# CODEX_PROFILES_JSON=[{"id":"codex-main","label":"Codex","provider":"codex","codexHome":"/home/ubuntu/.codex","workspaceCwd":"/srv/workspace","defaultProfile":true},{"id":"claude-main","label":"Claude","provider":"claude","codexHome":"/home/ubuntu/.claude","workspaceCwd":"/srv/workspace"},{"id":"gemini-main","label":"Gemini","provider":"gemini","codexHome":"/home/ubuntu/.gemini","workspaceCwd":"/srv/workspace"}]
#
# Windows multi-provider example:
# CODEX_PROFILES_JSON=[{"id":"codex-main","label":"Codex","provider":"codex","codexHome":"C:\\Users\\Administrator\\.codex","workspaceCwd":"D:\\workspace","defaultProfile":true},{"id":"claude-main","label":"Claude","provider":"claude","codexHome":"C:\\Users\\Administrator\\.claude","workspaceCwd":"D:\\workspace"},{"id":"gemini-main","label":"Gemini","provider":"gemini","codexHome":"C:\\Users\\Administrator\\.gemini","workspaceCwd":"D:\\workspace"}]
CODEX_PROFILES_JSON=[{"id":"codex-main","label":"Codex","provider":"codex","codexHome":"/home/ubuntu/.codex","workspaceCwd":"/srv/workspace","defaultProfile":true},{"id":"claude-main","label":"Claude","provider":"claude","codexHome":"/home/ubuntu/.claude","workspaceCwd":"/srv/workspace"},{"id":"gemini-main","label":"Gemini","provider":"gemini","codexHome":"/home/ubuntu/.gemini","workspaceCwd":"/srv/workspace"}]
